PORT=5000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Gemini API key (get from Google AI Studio / Google Cloud)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.0-flash"

# Default seeded account
DEFAULT_USER_ID="default-user-id"
DEFAULT_USER_EMAIL="tester@focustask.local"
DEFAULT_USER_NAME="FocusTask User"
DEFAULT_USER_BIO="Productivity enthusiast & FocusTask user."
DEFAULT_USER_AVATAR_URL=""
DEFAULT_USER_PASSWORD="12345678"

# Auth token
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_SECRET"
JWT_EXPIRES_IN="7d"
